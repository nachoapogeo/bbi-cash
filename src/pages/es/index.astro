---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import WhyBBI from '../../components/WhyBBI.astro';
import WhoWeServe from '../../components/WhoWeServe.astro';
import Contract from '../../components/Contract.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'es';
const t = getTranslations(locale);
---

<Layout
  title="BBI Cash ATMs — Servicios de Colocación de ATMs | Sur de Florida"
  description="BBI Cash instala ATMs gratis en negocios del sur de Florida. Sin costo, sin mantenimiento, ingreso mensual. PAI Alliance — procesamiento Brinks. Vinilos personalizados disponibles."
  lang={locale}
>
  <Nav t={t} locale={locale} />
  <Hero t={t} />
  <About t={t} />
  <HowItWorks t={t} />
  <WhyBBI t={t} />
  <WhoWeServe t={t} />
  <Contract t={t} />
  <Contact t={t} />
  <Footer />
</Layout>
