---
import type { Translations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
import { getAlternateLocales } from '../i18n/utils';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const locales = getAlternateLocales(locale);
const currentLabel = locale.toUpperCase();
---

<nav>
  <div class="nav-logo">
    BBI Cash
    <span>ATM Placement Services</span>
  </div>

  <div class="nav-right">
    <!-- Language dropdown — always visible -->
    <div class="lang-dropdown">
      <button class="lang-toggle" aria-label="Change language">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        {currentLabel}
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="lang-menu">
        {locales.map((l) => (
          <a href={l.path} class:list={[{ active: l.locale === locale }]}>{l.label}</a>
        ))}
      </div>
    </div>

    <!-- Hamburger button — mobile only -->
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Nav links -->
    <div class="nav-links">
      <a href="#about">{t.nav.about}</a>
      <a href="#how">{t.nav.how}</a>
      <a href="#why">{t.nav.why}</a>
      <a href="#who">{t.nav.who}</a>
      <a href="#contact" class="nav-cta">{t.nav.cta}</a>
    </div>
  </div>
</nav>

<!-- Mobile overlay -->
<div class="mobile-overlay"></div>

<style>
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ── Language dropdown ──────────────────────── */
  .lang-dropdown {
    position: relative;
  }
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.6);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    padding: 6px 10px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .lang-toggle:hover {
    border-color: rgba(201,160,64,0.4);
    color: var(--gold);
  }
  .lang-toggle svg {
    flex-shrink: 0;
  }
  .chevron {
    transition: transform 0.2s;
  }
  .lang-dropdown.open .chevron {
    transform: rotate(180deg);
  }
  .lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: rgba(11,31,15,0.97);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(201,160,64,0.2);
    border-radius: 8px;
    padding: 6px;
    min-width: 100px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s;
    z-index: 200;
  }
  .lang-dropdown.open .lang-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .lang-menu a {
    display: block;
    padding: 8px 14px;
    font-size: 0.8rem !important;
    font-weight: 500;
    color: rgba(255,255,255,0.5) !important;
    border-radius: 5px;
    transition: all 0.15s;
  }
  .lang-menu a:hover {
    background: rgba(201,160,64,0.1);
    color: var(--gold) !important;
  }
  .lang-menu a.active {
    color: var(--gold) !important;
    font-weight: 700;
  }

  /* ── Hamburger ──────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    width: 32px;
    height: 32px;
    z-index: 110;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(255,255,255,0.8);
    border-radius: 2px;
    transition: all 0.3s;
    transform-origin: center;
  }
  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ── Mobile overlay ─────────────────────────── */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 90;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .mobile-overlay.active {
    opacity: 1;
  }

  /* ── Mobile ─────────────────────────────────── */
  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -280px;
      width: 280px;
      height: 100vh;
      background: rgba(11,31,15,0.98);
      backdrop-filter: blur(12px);
      flex-direction: column;
      align-items: flex-start;
      padding: 80px 2rem 2rem;
      gap: 0;
      z-index: 100;
      transition: right 0.3s ease;
      border-left: 1px solid rgba(201,160,64,0.15);
      display: flex !important;
    }
    .nav-links.open {
      right: 0;
    }
    .nav-links a {
      width: 100%;
      padding: 14px 0;
      font-size: 1rem !important;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .nav-links .nav-cta {
      margin-top: 1rem;
      text-align: center;
      padding: 14px 20px !important;
      width: 100%;
      display: block;
    }
    .mobile-overlay.active {
      display: block;
      opacity: 1;
    }
  }
</style>

<script>
  function initNav() {
    const hamburger = document.querySelector('.hamburger');
    const navLinks = document.querySelector('.nav-links');
    const overlay = document.querySelector('.mobile-overlay');
    const langDropdown = document.querySelector('.lang-dropdown');
    const langToggle = document.querySelector('.lang-toggle');

    function closeMenu() {
      hamburger?.classList.remove('active');
      navLinks?.classList.remove('open');
      overlay?.classList.remove('active');
      hamburger?.setAttribute('aria-expanded', 'false');
    }

    function closeLang() {
      langDropdown?.classList.remove('open');
    }

    hamburger?.addEventListener('click', () => {
      const isOpen = navLinks?.classList.toggle('open');
      hamburger.classList.toggle('active');
      overlay?.classList.toggle('active');
      hamburger.setAttribute('aria-expanded', String(isOpen));
      closeLang();
    });

    overlay?.addEventListener('click', closeMenu);

    navLinks?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    langToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown?.classList.toggle('open');
    });

    document.addEventListener('click', (e) => {
      if (!langDropdown?.contains(e.target as Node)) {
        closeLang();
      }
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
