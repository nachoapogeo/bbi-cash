---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="contract">
  <span class="section-tag">{t.contract.tag}</span>
  <h2 class="section-h2 serif">{t.contract.h2_1}<br />{t.contract.h2_2}</h2>
  <p class="section-lead">{t.contract.lead}</p>
  <div class="contract-box">
    <div class="contract-header">
      <div class="contract-header-left">
        <h3 class="serif">{t.contract.header_title}</h3>
        <p>{t.contract.header_sub}</p>
      </div>
      <div class="contract-badge">{t.contract.badge}</div>
    </div>
    <div class="contract-body">
      {t.contract.items.map((item) => (
        <div class="contract-item">
          <div class="contract-check">✓</div>
          <div class="contract-item-text" set:html={item} />
        </div>
      ))}
    </div>
    <div class="contract-footer">{t.contract.footer}</div>
  </div>
</section>
