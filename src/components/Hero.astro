---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="hero">
  <div class="hero-pattern"></div>
  <div class="hero-tag">{t.hero.tag}</div>
  <h1 class="hero-h1 serif">
    {t.hero.h1_1}<br />
    {t.hero.h1_2}<br />
    <em>{t.hero.h1_em}</em>
  </h1>
  <p class="hero-sub">{t.hero.sub}</p>
  <div class="hero-actions">
    <a href="#contact" class="btn-primary">{t.hero.cta}</a>
    <a href="#how" class="btn-ghost">{t.hero.ghost}</a>
  </div>
  <div class="hero-stats">
    {t.hero.stats.map((s) => (
      <div class="stat-item">
        <span class="stat-num">{s.num}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
  <div class="hero-badge">
    <div class="badge-ring">
      <div class="badge-inner">
        <span class="badge-main serif">BBI</span>
        <span class="badge-sub">Cash ATMs</span>
      </div>
    </div>
  </div>
</section>
<div class="gold-line"></div>
