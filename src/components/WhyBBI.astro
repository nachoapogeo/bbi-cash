---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="why">
  <span class="section-tag">{t.why.tag}</span>
  <h2 class="section-h2 serif">{t.why.h2_1}<br />{t.why.h2_2}</h2>
  <p class="section-lead">{t.why.lead}</p>
  <div class="why-grid">
    {t.why.cards.map((c) => (
      <div class="why-card">
        <span class="why-card-icon">{c.icon}</span>
        <div class="why-card-title">{c.title}</div>
        <div class="why-card-text">{c.text}</div>
      </div>
    ))}
    <div class="why-card featured">
      <div class="why-featured-img">
        🎨
        <span>Custom Wrap</span>
      </div>
      <div>
        <div class="why-featured-label">{t.why.featured.label}</div>
        <div class="why-featured-title serif">{t.why.featured.title}</div>
        <div class="why-featured-text">{t.why.featured.text}</div>
      </div>
    </div>
  </div>
</section>
