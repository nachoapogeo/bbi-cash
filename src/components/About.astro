---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about">
  <span class="section-tag">{t.about.tag}</span>
  <h2 class="section-h2 serif">{t.about.h2_1}<br />{t.about.h2_2}</h2>
  <div class="about-grid">
    <div class="about-text">
      {t.about.paragraphs.map((p) => (
        <p set:html={p} />
      ))}
    </div>
    <div class="about-cards">
      {t.about.cards.map((c) => (
        <div class="about-card">
          <div class="about-card-title">{c.title}</div>
          <div class="about-card-text">{c.text}</div>
        </div>
      ))}
    </div>
  </div>
</section>
