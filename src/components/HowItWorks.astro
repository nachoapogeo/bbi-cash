---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="how">
  <span class="section-tag">{t.how.tag}</span>
  <h2 class="section-h2 serif">{t.how.h2_1}<br />{t.how.h2_2}</h2>
  <p class="section-lead">{t.how.lead}</p>
  <div class="steps">
    {t.how.steps.map((s) => (
      <div class="step">
        <span class="step-num serif">{s.num}</span>
        <div class="step-icon">{s.icon}</div>
        <div class="step-title">{s.title}</div>
        <div class="step-text">{s.text}</div>
        <div class="step-time">{s.time}</div>
      </div>
    ))}
  </div>
</section>
