---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="contact">
  <span class="section-tag">{t.contact.tag}</span>
  <p class="contact-oneliner serif">
    {t.contact.oneliner_1}<br />
    {t.contact.oneliner_2}<br />
    {t.contact.oneliner_3} <em>{t.contact.oneliner_em}</em>
  </p>
  <div class="contact-cta-block">
    <p class="contact-reply">
      {t.contact.reply_1}<br />
      {t.contact.reply_2} <strong>{t.contact.reply_strong}</strong><br />
      {t.contact.reply_3}
    </p>
    <a href="mailto:bbicashinfo@gmail.com?subject=ATM Placement Inquiry" class="btn-primary-large">
      {t.contact.cta}
    </a>
  </div>
  <div class="contact-details">
    {t.contact.details.map((d) => (
      <div class="contact-detail">
        <div class="contact-detail-label">{d.label}</div>
        <div class="contact-detail-value">{d.value}</div>
      </div>
    ))}
  </div>
  <div class="lang-bar">SE HABLA ESPAÑOL &nbsp;·&nbsp; FALAMOS PORTUGUÊS &nbsp;·&nbsp; ENGLISH</div>
</section>
