---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="who">
  <span class="section-tag">{t.who.tag}</span>
  <h2 class="section-h2 serif">{t.who.h2_1}<br />{t.who.h2_2}</h2>
  <p class="section-lead">{t.who.lead}</p>
  <div class="who-grid">
    {t.who.businesses.map((b) => (
      <div class="who-card">
        <span class="who-icon">{b.icon}</span>
        <div class="who-title">{b.title}</div>
        <div class="who-text">{b.text}</div>
      </div>
    ))}
  </div>
</section>
